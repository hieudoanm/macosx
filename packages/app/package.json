    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "kill-port": "2.0.1",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "rimraf": "6.1.3",
    "tailwindcss": "4.2.2",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "6.0.2"
  }
