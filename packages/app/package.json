  "scripts": {
    "lint": "eslint . --fix",
    "format": "prettier --cache --write .",
    "docs": "rimraf docs && docsify init ./docs && touch ./docs/.nojekyll",
    "predev": "rimraf .next && kill-port 3000",
    "dev": "next dev --turbopack && tauri dev",
    "pretest": "jest --clearCache",
    "test": "jest",
    "prebuild": "rimraf ./src-tauri/bin/wifi ./src-tauri/target .next out && make build",
    "build": "next build --turbopack",
    "build:tauri": "tauri build",
    "prestart": "kill-port 3000 || true",
    "start": "next start",
    "tauri": "tauri",
    "dev:desktop": "tauri dev",
    "build:desktop": "tauri build"
  },
  "dependencies": {
    "@capacitor/android": "8.3.0",
    "@capacitor/core": "8.3.0",
    "@capacitor/ios": "8.3.0",
    "@tauri-apps/api": "2.10.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0"
  },
  "devDependencies": {
    "@capacitor/cli": "8.3.0",
    "@eslint/eslintrc": "3.3.5",
    "@tailwindcss/postcss": "4.2.2",
    "@tauri-apps/cli": "2.10.1",
    "@testing-library/jest-dom": "6.9.1",
